ALEXANDRIA_API_URL=http://localhost:8080
ALEXANDRIA_API_KEY=dev-admin-key
# Directory containing the source portal CSVs and generated import CSVs
ALEXANDRIA_DATA_DIR=/path/to/your/data/directory
# Container name for the Alexandria DB (used by generate_report.py for fuzzy matching)
ALEXANDRIA_DB_CONTAINER=alexandria-db
# Path to the directory containing the snapshot files
ALEXANDRIA_CORPUS_PATH=/path/to/your/corpus/directory
# Path to the alexandria-nexus repo (used to start the stack if not running)
ALEXANDRIA_NEXUS_DIR=/path/to/alexandria-nexus

